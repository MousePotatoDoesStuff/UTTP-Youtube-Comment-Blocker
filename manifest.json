{
  "manifest_version": 3,
  "name": "YouTube UTTP Blocker",
  "version": "0.1",
  "description": "Blocks comments and replies from accounts containing 'UTTP' in their username.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}